PORT=3000

# Database
POSTGRES_USER=loveflix
POSTGRES_PASSWORD=secret
POSTGRES_DB=loveflix
POSTGRES_PORT=5432
DATABASE_URL=postgresql://loveflix:secret@localhost:5432/loveflix

# Auth — must be set to a strong random value in production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Cloudflare R2 — all four fields are required at startup
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=loveflix-media
R2_PUBLIC_URL=

# App
BASE_URL=http://localhost:3000

# CORS — comma-separated origins or * for all (restrict in production)
CORS_ORIGIN=http://localhost:3000

# Logging — trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info
