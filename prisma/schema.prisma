generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WebsiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  PHOTO
  VIDEO
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  name         String?
  websites     CoupleWebsite[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([email])
}

model CoupleWebsite {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  slug            String        @unique
  title           String
  partnerName1    String
  partnerName2    String
  anniversaryDate DateTime?
  message         String?       @db.Text
  theme           String        @default("classic")
  status          WebsiteStatus @default(DRAFT)
  media           Media[]
  mediaRows       MediaRow[]
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([userId])
  @@index([slug])
}

model Media {
  id        String        @id @default(uuid())
  websiteId String
  website   CoupleWebsite @relation(fields: [websiteId], references: [id])
  type      MediaType
  url       String
  key       String
  fileName  String
  sizeBytes Int
  mimeType  String
  sortOrder Int           @default(0)
  caption   String?
  createdAt DateTime      @default(now())
  deletedAt DateTime?
  rowItems  MediaRowItem[]

  @@index([websiteId])
}

model MediaRow {
  id        String        @id @default(uuid())
  websiteId String
  website   CoupleWebsite @relation(fields: [websiteId], references: [id])
  name      String
  sortOrder Int           @default(0)
  items     MediaRowItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@unique([websiteId, name])
  @@index([websiteId])
}

model MediaRowItem {
  id        String   @id @default(uuid())
  rowId     String
  row       MediaRow @relation(fields: [rowId], references: [id])
  mediaId   String
  media     Media    @relation(fields: [mediaId], references: [id])
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([rowId, mediaId])
  @@index([rowId])
}
