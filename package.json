{
    "name": "pallet",
    "version": "1.0.0",
    "description": "",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "start": "node dist/server.js",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test:ui": "vitest --ui"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "cors": "^2.8.5",
        "express": "^5.2.1",
        "pino": "^8.19.0",
        "pino-pretty": "^10.3.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.6",
        "@types/node": "^22.10.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "eslint": "^8.57.0",
        "prisma": "^5.22.0",
        "tsc-alias": "^1.8.10",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.2.4",
        "vitest-mock-extended": "^3.1.0"
    }
}
